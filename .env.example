GEMINI_API_KEY="your-gemini-api-key"
VITE_GEMINI_API_KEY="your-gemini-api-key"
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key"
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key"
VITE_FIREBASE_API_KEY="your-firebase-api-key"
VITE_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
VITE_FIREBASE_DATABASE_URL="https://your-project-default-rtdb.firebaseio.com"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="your-sender-id"
VITE_FIREBASE_APP_ID="your-app-id"
VITE_SANDBOX_URL="http://localhost:4200"
VITE_BACKEND_URL="http://localhost:4200"
WA_LOG_LEVEL="silent"
WA_SYNC_FULL_HISTORY="true"
WA_HISTORY_LIMIT="50000"
WA_HISTORY_RESPONSE_LIMIT="2000"

# Ollama (optional, for local LLM proxy)
# OLLAMA_BASE_URL="http://localhost:11434"

# Cerebras (optional, for browser automation + document gen)
# CEREBRAS_API_KEY="your-cerebras-api-key"

# OpenCode CLI path (optional, for sandbox sub-agent)
# OPENCODE_PATH="/opt/homebrew/bin/opencode"

# WhatsApp Cloud API (optional, overrides Baileys)
# WHATSAPP_ACCESS_TOKEN=""
# WHATSAPP_PHONE_NUMBER_ID=""
# WHATSAPP_BUSINESS_ACCOUNT_ID=""
# WHATSAPP_APP_ID=""

# Baileys auth storage (optional)
# WA_AUTH_ROOT="/opt/.baileys_auth"
