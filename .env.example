# ── Beatrice Environment Template ──
# All Eburon-branded keys. No upstream provider/model brand names.

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Eburon AI (server-side private keys — never use VITE_)
EBURON_AI_API_KEY=
EBURON_CORE_KEY=
EBURON_CORE_PROVIDER=eburon_core
EBURON_TEXT_MODEL=eburon_text
EBURON_VOICE_MODEL=eburon_realtime_voice
EBURON_VISION_MODEL=eburon_vision
EBURON_WORKER_MODEL=eburon_worker

# Private upstream model IDs (server-side only)
EBURON_TEXT_MODEL_ID_INTERNAL=
EBURON_VOICE_MODEL_ID_INTERNAL=
EBURON_VISION_MODEL_ID_INTERNAL=
EBURON_WORKER_MODEL_ID_INTERNAL=
EBURON_FAST_MULTIMODAL_MODEL_ID_INTERNAL=

# Public frontend label
VITE_EBURON_PUBLIC_MODEL_LABEL=Eburon

# Firebase Auth
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Image generation
VITE_IMAGE_GEN_API_KEY=

# WhatsApp (Baileys)
VITE_BACKEND_URL=http://localhost:4200
VITE_SANDBOX_URL=http://localhost:4200
WA_AUTH_ROOT=./baileys_auth
WA_LOG_LEVEL=info

# Cerebras browser automation
CEREBRAS_API_KEY=

# Google Maps
GOOGLE_MAPS_API_KEY=

# Server
PORT=4200

# Optional: Sandbox env
SANDBOX_ROOT=
VITE_APP_URL=http://localhost:3000

# OpenCode Zen free-model swap chain (server-side openterminal).
# Comma-separated opencode/<model> ids tried in order when the primary runs
# out of free tokens. Override here, or leave blank to use defaults baked into
# server/index.ts (OPENCODE_ZEN_FREE_MODELS).
OPENCODE_ZEN_FREE_MODELS=
# Dedicated single-model fallbacks (defaults live in server/index.ts).
OPENCODE_MODEL=
OPENCODE_FALLBACK_MODEL=
OPEN_TERMINAL_FALLBACK_MODEL=

# ── Coding Agent Provider Config (server-side only, never exposed to frontend) ──
# Default provider for /api/coding-agent/run (opencode | gemini | freebuff | codebuff)
CODING_AGENT_DEFAULT=opencode
# Provider binary paths
OPENCODE_PATH=opencode
GEMINI_CLI_PATH=gemini
# Freebuff & Codebuff are the same tool (CodebuffAI). Freebuff = free, Codebuff = paid.
# FREEBUFF_PATH is canonical; CODEBUFF_PATH is used if Freebuff isn't installed.
FREEBUFF_PATH=freebuff
CODEBUFF_PATH=codebuff
