{
  "name": "beatrice",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "author": {
    "name": "Eburon AI",
    "email": "hello@eburon.ai"
  },
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --port=3000 --strictPort --host=0.0.0.0",
    "dev:api": "tsx server/index.ts",
    "dev:full": "npm run dev:api & npm run dev",
    "build": "vite build",
    "electron:dev": "vite build && electron .",
    "electron:build:mac": "vite build && electron-builder --mac --universal",
    "electron:build:linux": "vite build && electron-builder --linux",
    "electron:build:win": "vite build && electron-builder --win",
    "electron:build:all": "vite build && electron-builder --mac --universal --linux --win",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "start": "tsx server/index.ts",
    "lint": "tsc --noEmit",
    "docker:whatsapp:build": "docker compose -f docker-compose.whatsapp.yml build",
    "docker:whatsapp:up": "docker compose -f docker-compose.whatsapp.yml up",
    "docker:whatsapp:down": "docker compose -f docker-compose.whatsapp.yml down",
    "smoke:whatsapp": "node scripts/smoke-whatsapp-server.mjs",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:migrate": "supabase migration up",
    "db:studio": "echo 'Supabase Studio: http://127.0.0.1:54323'",
    "check:eburon-branding": "node scripts/check-eburon-branding.mjs"
  },
  "build": {
    "appId": "ai.eburon.beatrice",
    "productName": "Beatrice",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/icon-eburon.svg",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "public/icon-eburon.svg",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "artifactName": "Beatrice-${version}-mac-${arch}.${ext}"
    },
    "linux": {
      "category": "Office",
      "icon": "public/icon-eburon.svg",
      "target": [
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Beatrice-${version}-linux-${arch}.${ext}"
    },
    "win": {
      "icon": "public/icon-eburon.svg",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Beatrice-${version}-win-${arch}.${ext}"
    }
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@hapi/boom": "^10.0.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@monaco-editor/react": "^4.7.0",
    "@supabase/supabase-js": "^2.106.2",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "@whiskeysockets/baileys": "^7.0.0-rc13",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "cors": "^2.8.6",
    "dexie": "^4.4.3",
    "dexie-react-hooks": "^4.4.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "fflate": "^0.8.3",
    "firebase": "^12.12.1",
    "html2canvas": "^1.4.1",
    "http-proxy": "^1.18.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.2.0",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "puppeteer": "^24.0.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-markdown": "^10.1.0",
    "swagger-ui-express": "^5.0.1",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@firebase/eslint-plugin-security-rules": "^0.0.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.14.0",
    "@types/qrcode": "^1.5.6",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "eslint": "^10.2.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
