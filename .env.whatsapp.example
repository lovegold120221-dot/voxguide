# Copy to .env.whatsapp before running docker compose.
# All Eburon-branded keys. No upstream provider/model brand names.

SANDBOX_PORT=4300
WHATSAPP_SERVER_PORT=4300
WA_AUTH_ROOT=/data/baileys
WA_LOG_LEVEL=silent
WA_SYNC_FULL_HISTORY=true
WA_HISTORY_LIMIT=50000
WA_HISTORY_RESPONSE_LIMIT=2000

# Ollama endpoint (Docker gateway IP for host-localhost access)
OLLAMA_BASE_URL=http://172.16.1.1:11434

# Optional: Cerebras browser automation
CEREBRAS_API_KEY=

# Eburon Core provider (required for AI features)
EBURON_CORE_KEY=

# Supabase (local or remote)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# GitHub token for eburon-multimodal-pro GitHub skills (repo ops, PRs, issues, code review)
GITHUB_TOKEN=
